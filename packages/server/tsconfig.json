{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@bucketer/shared": ["../shared/types.ts"]
    }
  },
  "include": ["src", "../shared/src"]
}
